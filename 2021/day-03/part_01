#!/usr/bin/env bash

mapfile -t list <sample.txt
# mapfile -t list <input.txt

gamma=()
epsilon=0

x_len=$((${#list[@]}))
x_half=$((x_len/2))
y_len=$((${#list[0]}))


for ((i=0; i< $y_len; i++)); do
  line=()
  for ((j = 0; j < $x_len; j++)); do
    line+=${list[j]:0:i}
  done

  echo line $line
  ones=()
  ones=$(echo $line | grep -o '1' | wc -l)
  echo ones $ones

  if [ $ones -gt $x_half ]; then
    gamma+=1
  else
    gamma+=0
  fi
done

echo gamma "${gamma[@]}"


calculate_gamma() {
  return gamma
}
